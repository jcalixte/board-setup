#!/usr/bin/env python3
"""printboard — print the Enabler board's papers at the right size, count, and version.

The papers live as slides in one Google Slides deck (the source of truth others edit).
On each run we export that deck to a single PDF, find each paper's slide *by its title*,
and send it to the printer at the size and number of copies declared in manifest.json.

  printboard first-time            # whole board, first-time variant where it exists
  printboard generic               # whole board, generic variant
  printboard generic tech-working-conditions   # just one paper (a named paper prints 1 copy)
  printboard generic takt --count 5             # a named paper, but this many copies
  printboard first-time --count 3 --dry-run
  printboard generic --to-pdf "~/Downloads/board.pdf"    # export a PDF instead of printing
  printboard generic --from-pdf "~/Downloads/deck.pdf"   # skip export, use a local PDF
  printboard --list-titles --from-pdf "~/Downloads/deck.pdf"   # debug: page -> title

Version is required and never guessed (single-version papers print in either mode).
"""
from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
from concurrent.futures import ThreadPoolExecutor
from pathlib import Path

HERE = Path(__file__).resolve().parent          # installed: libexec; in repo: the repo dir


def resolve_manifest(cli_arg: str | None) -> Path:
    """Find manifest.json: --manifest > $PRINTBOARD_MANIFEST > ~/.config > bundled."""
    candidates = []
    if cli_arg:
        candidates.append(Path(cli_arg).expanduser())
    if os.environ.get("PRINTBOARD_MANIFEST"):
        candidates.append(Path(os.environ["PRINTBOARD_MANIFEST"]).expanduser())
    candidates.append(Path.home() / ".config" / "printboard" / "manifest.json")
    candidates.append(HERE / "manifest.json")     # bundled default
    for c in candidates:
        if c.exists():
            return c
    die("no manifest.json found (looked at --manifest, $PRINTBOARD_MANIFEST, "
        "~/.config/printboard/manifest.json, and the bundled copy).")


CONFIG_PATH = Path.home() / ".config" / "printboard" / "config.json"


def load_config() -> dict:
    """Per-user, per-machine settings (deck id, remote, printer) — never shipped."""
    try:
        return json.loads(CONFIG_PATH.read_text())
    except FileNotFoundError:
        return {}
    except json.JSONDecodeError:
        die(f"{CONFIG_PATH} is not valid JSON.")


def save_config(cfg: dict) -> None:
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    CONFIG_PATH.write_text(json.dumps(cfg, indent=2) + "\n")


def effective_deck(manifest: dict, config: dict) -> dict:
    """Deck identity comes from local config (the doc_id is private); the manifest
    only carries a default remote name."""
    deck = dict(manifest.get("deck", {}))
    deck["rclone_remote"] = config.get("rclone_remote") or deck.get("rclone_remote") or "gdrive"
    if config.get("doc_id"):
        deck["doc_id"] = config["doc_id"]
    return deck


def extract_doc_id(raw: str) -> str | None:
    """Accept a Google Slides URL or a bare file id."""
    raw = raw.strip()
    m = re.search(r"/d/([A-Za-z0-9_-]+)", raw)
    if m:
        return m.group(1)
    return raw if re.fullmatch(r"[A-Za-z0-9_-]{20,}", raw) else None


def die(msg: str, code: int = 1):
    print(f"printboard: {msg}", file=sys.stderr)
    sys.exit(code)


def warn(msg: str):
    print(f"  ⚠️  {msg}", file=sys.stderr)


def normalize(s: str) -> str:
    """Casefold, treat all dashes/punctuation as spaces, collapse whitespace.

    So 'Questionnaire — template', 'Questionnaire - template' and
    'Questionnaire template' all compare equal — the separator never matters.
    """
    s = re.sub(r"[^\w\s]", " ", s, flags=re.UNICODE)   # dashes, punctuation, badges → space
    s = re.sub(r"\s+", " ", s)
    return s.strip().casefold()


# ---------- get the deck as a PDF ----------

def export_deck(deck: dict, dest: Path) -> Path:
    """Export the live Slides deck to PDF via rclone.

    Addressed by doc_id (`rclone backend copyid`), so the remote's root or chosen
    Shared Drive is irrelevant — only that the account can see the deck.
    """
    if not shutil.which("rclone"):
        die("rclone is not installed — run `printboard setup` (or `brew install rclone`). "
            "Or pass --from-pdf <file> to print from a local export.")
    remote = deck.get("rclone_remote")
    doc_id = deck.get("doc_id")
    if not (remote and doc_id):
        die("no deck configured — run `printboard setup` to save the deck id.")
    outdir = dest / "export"
    outdir.mkdir(parents=True, exist_ok=True)
    cmd = ["rclone", "backend", "copyid", f"{remote}:", doc_id,
           f"{outdir}/", "--drive-export-formats", "pdf"]
    print("→ exporting live deck from Drive…")
    res = subprocess.run(cmd)
    if res.returncode != 0:
        die("rclone export failed — check auth with `printboard doctor`.")
    pdfs = sorted(outdir.glob("*.pdf"))
    if not pdfs:
        die("rclone produced no PDF — is deck.doc_id correct?")
    return pdfs[0]


# ---------- read the PDF ----------

def page_texts(pdf: Path) -> list[str]:
    """Return the text of each page (split on form-feed from a single pdftotext pass)."""
    if not shutil.which("pdftotext"):
        die("pdftotext not found — install poppler (brew install poppler).")
    res = subprocess.run(["pdftotext", "-layout", str(pdf), "-"],
                         capture_output=True, text=True)
    if res.returncode != 0:
        die(f"pdftotext failed: {res.stderr.strip()}")
    pages = res.stdout.split("\x0c")
    # pdftotext emits a trailing empty chunk after the last form-feed
    if pages and pages[-1].strip() == "":
        pages.pop()
    return pages


def page_lines(text: str) -> list[str]:
    return [ln.strip() for ln in text.splitlines() if ln.strip()]


def find_page(title: str, pages: list[str]) -> tuple[list[int], list[int]]:
    """Return (strong, fuzzy) 1-based page lists for a title.

    strong = a standalone line on the page equals the title (the dedicated paper slide).
    fuzzy  = the title only appears as a substring of some line (likely a list/spec slide).
    """
    target = normalize(title)
    strong, fuzzy = [], []
    for i, text in enumerate(pages, start=1):
        lines = page_lines(text)
        head = normalize(" ".join(lines[:3]))   # title region: a version word on a 2nd line still counts
        full = normalize(" ".join(lines))
        if head == target or head.startswith(target + " "):
            strong.append(i)
        elif target in full:                     # appears elsewhere → likely a list/spec slide
            fuzzy.append(i)
    return strong, fuzzy


def assign_paper_pages(paper: dict, pages: list[str]) -> dict:
    """Resolve each of a paper's versions to one page.

    A page matched by several of the paper's variant titles is assigned to the most
    specific (longest) one — so `<Paper> - template` claims its slide and the bare
    `<Paper>` slide falls to the generic variant, without stamping "generic" on it.
    Returns {version: {title, page, status, pages}} where status is
    ok | ambiguous | fuzzy | none. No warnings here — the caller reports per request.
    """
    titles = {v: (s["title"] if isinstance(s, dict) else s)
              for v, s in paper.get("variants", {}).items()}
    matches = {v: find_page(t, pages) for v, t in titles.items()}   # v -> (strong, fuzzy)
    owner = {}
    for v in sorted(titles, key=lambda v: len(normalize(titles[v])), reverse=True):
        for pg in matches[v][0]:
            owner.setdefault(pg, v)
    info = {}
    for v, t in titles.items():
        strong, fuzzy = matches[v]
        owned = [pg for pg in strong if owner.get(pg) == v]
        if len(owned) == 1:
            info[v] = {"title": t, "page": owned[0], "status": "ok", "pages": owned}
        elif len(owned) > 1:
            info[v] = {"title": t, "page": None, "status": "ambiguous", "pages": owned}
        elif fuzzy:
            info[v] = {"title": t, "page": None, "status": "fuzzy", "pages": fuzzy}
        else:
            info[v] = {"title": t, "page": None, "status": "none", "pages": []}
    return info


# ---------- printing ----------

PORTRAIT_PT = {"A4": (595, 842), "A3": (842, 1191)}   # width, height in points


def media_points(size: str, orientation: str) -> tuple[int, int]:
    w, h = PORTRAIT_PT[size]
    return (h, w) if orientation == "landscape" else (w, h)


def scale_page(pdf: Path, page: int, size: str, orientation: str,
               dest_dir: Path, margin_mm: float = 0.0) -> Path:
    """Size one page to its target media (vector, via ghostscript), so it prints
    full-size on any printer regardless of the driver's fit-to-page behaviour.

    The deck slides are ~A4-sized and printers won't scale them up to A3, so we do it
    here. With margin_mm > 0 the content is inset by that margin (centred); with 0 it
    fills the sheet edge-to-edge (keep content off the edges in the slide design).
    """
    if not shutil.which("gs"):
        die("ghostscript not found — `brew install ghostscript` (needed to size pages to A3/A4).")
    if size not in PORTRAIT_PT:
        die(f"unknown size '{size}' (expected A3 or A4).")
    w, h = media_points(size, orientation)
    m = round(margin_mm * 72 / 25.4)
    out = dest_dir / f"sized-{page}-{size}.pdf"

    def gs(args):
        return subprocess.run(["gs", "-q", "-sDEVICE=pdfwrite", "-dFIXEDMEDIA",
                               "-dAutoRotatePages=/None", *args], capture_output=True, text=True)

    if m <= 0:
        # full bleed: fit content to the whole media in one pass
        p = gs(["-o", str(out), f"-dDEVICEWIDTHPOINTS={w}", f"-dDEVICEHEIGHTPOINTS={h}",
                "-dPDFFitPage", f"-dFirstPage={page}", f"-dLastPage={page}", str(pdf)])
        if not out.exists():
            die(f"ghostscript failed to size page {page}: {p.stderr.strip()[:200]}")
        return out

    # margin: fit content into the inner box, then centre that box on the full media
    bw, bh = w - 2 * m, h - 2 * m
    box = dest_dir / f"box-{page}-{size}.pdf"
    p1 = gs(["-o", str(box), f"-dDEVICEWIDTHPOINTS={bw}", f"-dDEVICEHEIGHTPOINTS={bh}",
             "-dPDFFitPage", f"-dFirstPage={page}", f"-dLastPage={page}", str(pdf)])
    p2 = (gs(["-o", str(out), f"-dDEVICEWIDTHPOINTS={w}", f"-dDEVICEHEIGHTPOINTS={h}",
              "-c", f"<</PageOffset [{m} {m}]>> setpagedevice", "-f", str(box)])
          if box.exists() else p1)
    if not out.exists():
        die(f"ghostscript failed to size page {page}: {(p2.stderr or p1.stderr or '').strip()[:200]}")
    return out


def lp_command(pdf: Path, count: int, size: str,
               printer: str | None, lp_options: list[str]) -> list[str]:
    """Print an already-correctly-sized PDF at 100% (no CUPS scaling)."""
    cmd = ["lp"]
    if printer:
        cmd += ["-d", printer]
    cmd += ["-n", str(count), "-o", f"media={size}"]
    for opt in lp_options:
        cmd += ["-o", opt]
    cmd.append(str(pdf))
    return cmd


def merge_pdfs(pages: list[Path], dest: Path) -> None:
    """Concatenate already-sized pages into one PDF, keeping each page's A3/A4 media
    (no -dFIXEDMEDIA here, so ghostscript preserves per-page sizes)."""
    if not shutil.which("gs"):
        die("ghostscript not found — `brew install ghostscript` (needed to build the PDF).")
    dest.parent.mkdir(parents=True, exist_ok=True)
    res = subprocess.run(["gs", "-q", "-dNOPAUSE", "-dBATCH", "-sDEVICE=pdfwrite",
                          "-dAutoRotatePages=/None", f"-sOutputFile={dest}",
                          *[str(p) for p in pages]], capture_output=True, text=True)
    if not dest.exists():
        die(f"ghostscript failed to write {dest}: {res.stderr.strip()[:200]}")


# ---------- choosing a printer ----------

MEDIA_QUERY_TIMEOUT = 3.0   # `lpoptions -l` blocks ~6s per offline printer; cap it


def _lpoptions(name: str, extra: list[str] = (), timeout: float | None = None) -> str | None:
    """`lpoptions -p <name> [extra]` stdout, or None if it timed out (offline printer).

    errors="replace": printer info/location/status can carry non-UTF-8 bytes (e.g.
    Mac Roman accents), which would otherwise crash strict text decoding in a UTF-8
    locale. We only parse ASCII keys, so replacing a stray byte is harmless.
    """
    try:
        return subprocess.run(["lpoptions", "-p", name, *extra], capture_output=True,
                              text=True, errors="replace", timeout=timeout).stdout
    except subprocess.TimeoutExpired:
        return None


def _opt_value(blob: str, key: str) -> str | None:
    """Pull key=value out of `lpoptions -p` output; values may be 'single-quoted'."""
    m = re.search(rf"(?:^|\s){re.escape(key)}=('([^']*)'|(\S+))", blob)
    if not m:
        return None
    return m.group(2) if m.group(2) is not None else m.group(3)


def _media_support(name: str) -> tuple[bool | None, bool | None]:
    """(a3, a4) media support; (None, None) if the printer didn't answer in time."""
    out = _lpoptions(name, ["-l"], timeout=MEDIA_QUERY_TIMEOUT)
    if out is None:
        return None, None
    for line in out.splitlines():
        key = line.split("/", 1)[0].strip().lower()
        if key in ("pagesize", "media", "mediasize", "pageregion"):
            vals = line.split(":", 1)[1] if ":" in line else ""
            return bool(re.search(r"\bA3\b", vals)), bool(re.search(r"\bA4\b", vals))
    return False, False


def list_printers() -> list[dict]:
    """[{name, info, model, a3, a4}] for every configured CUPS destination.

    A3/A4 detection needs `lpoptions -l`, which blocks ~6s per *offline* network
    printer on a CUPS timeout — 15 printers would be ~45s serially. So query them
    in parallel with a short timeout; printers that don't answer come back with
    a3/a4 = None (shown as "?").
    """
    if not (shutil.which("lpstat") and shutil.which("lpoptions")):
        die("lpstat/lpoptions not found — CUPS ships with macOS.")
    names = [ln.strip() for ln in
             subprocess.run(["lpstat", "-e"], capture_output=True, text=True,
                            errors="replace").stdout.splitlines()
             if ln.strip()]
    if not names:
        return []

    def describe(n: str) -> dict:
        blob = _lpoptions(n) or ""
        a3, a4 = _media_support(n)
        return {"name": n, "info": _opt_value(blob, "printer-info") or n,
                "model": _opt_value(blob, "printer-make-and-model") or "",
                "a3": a3, "a4": a4}

    with ThreadPoolExecutor(max_workers=min(16, len(names))) as ex:
        return list(ex.map(describe, names))


def current_printer(config: dict, manifest: dict) -> tuple[str | None, str]:
    """Resolve the printer printboard would use right now, and where it came from."""
    if config.get("printer"):
        return config["printer"], "printboard config"
    if manifest.get("print", {}).get("printer"):
        return manifest["print"]["printer"], "manifest"
    txt = subprocess.run(["lpstat", "-d"], capture_output=True, text=True,
                         errors="replace").stdout.strip()
    name = txt.rsplit(":", 1)[1].strip() if ":" in txt else ""   # localized prefix, name after ':'
    return (name, "system default") if name else (None, "none")


def _save_printer(config: dict, printers: list[dict], name: str) -> int:
    p = next((x for x in printers if x["name"] == name), None)
    config["printer"] = name
    save_config(config)
    label = f" ({p['info']})" if p and p["info"] != name else ""
    print(f"✓ printboard will print to '{name}'{label}.")
    if p and p["a3"] is False:
        warn(f"{name} doesn't advertise A3 — the board's A3 papers may print wrong. "
             "Choose an A3-capable printer if you print those.")
    elif p and p["a3"] is None:
        warn(f"couldn't check {name}'s paper sizes (offline?) — confirm it does A3 "
             "before printing the board.")
    return 0


def cmd_printer(argv: list[str]) -> int:
    """Show, choose, or clear the printer printboard prints to (saved in local config)."""
    ap = argparse.ArgumentParser(
        prog="printboard printer",
        description="Choose the default printer printboard sends to (saved in your local config, "
                    "printboard only). No name → an interactive menu.")
    ap.add_argument("name", nargs="?", help="printer queue name to set (omit for the menu)")
    ap.add_argument("--manifest", default=None)
    ap.add_argument("--list", action="store_true", help="just list printers, change nothing")
    ap.add_argument("--unset", action="store_true",
                    help="forget the saved printer (fall back to the system default)")
    args = ap.parse_args(argv)

    manifest = json.loads(resolve_manifest(args.manifest).read_text())
    config = load_config()

    if args.unset:
        if config.pop("printer", None) is None:
            print("No printboard printer was set — nothing to unset.")
        else:
            save_config(config)
            print("✓ Unset — printboard will use the system default (set with `lpoptions -d`).")
        return 0

    printers = list_printers()
    if not printers:
        die("no printers configured on this Mac (add one in System Settings → Printers).")
    cur, src = current_printer(config, manifest)

    if args.name:
        if args.name not in {p["name"] for p in printers}:
            die(f"unknown printer '{args.name}'. Run `printboard printer --list` to see the names.")
        return _save_printer(config, printers, args.name)

    print(f"Current printer: {cur or '(none)'}  [{src}]\n")
    print("Available printers  (A3 needed for the board's A3 papers;  ? = offline / couldn't check):\n")
    for i, p in enumerate(printers, 1):
        badge = ("A3+A4" if p["a3"] and p["a4"] else
                 "A4 only" if p["a4"] else "A3 only" if p["a3"] else "?")
        mark = "  ← current" if p["name"] == cur else ""
        model = f"  {p['model']}" if p["model"] else ""
        print(f"  {i:>2}. [{badge:<7}]  {p['info']:<30} {p['name']}{model}{mark}")

    if args.list:
        return 0
    if not sys.stdin.isatty():
        print("\nNot a terminal — set one with:  printboard printer <name>")
        return 0

    choice = input("\nSelect a number (Enter = keep current, u = unset): ").strip()
    if not choice:
        print("Kept current.")
        return 0
    if choice.lower() == "u":
        config.pop("printer", None)
        save_config(config)
        print("✓ Unset — printboard will use the system default.")
        return 0
    if not (choice.isdigit() and 1 <= int(choice) <= len(printers)):
        die("not a valid selection.")
    return _save_printer(config, printers, printers[int(choice) - 1]["name"])


def cmd_doctor(argv: list[str]) -> int:
    """Check the environment can export the deck and print."""
    ap = argparse.ArgumentParser(prog="printboard doctor")
    ap.add_argument("--manifest", default=None)
    args = ap.parse_args(argv)
    manifest = json.loads(resolve_manifest(args.manifest).read_text())
    deck = effective_deck(manifest, load_config())
    remote = deck.get("rclone_remote", "gdrive")
    ok = True

    def check(label, good, hint=""):
        nonlocal ok
        print(f"  {'✓' if good else '✗'} {label}")
        if not good and hint:
            print(f"      → {hint}")
        ok = ok and good

    print("printboard doctor\n")
    check("rclone installed", bool(shutil.which("rclone")),
          "brew install rclone, then `printboard setup`")
    check("pdftotext installed", bool(shutil.which("pdftotext")), "brew install poppler")
    check("ghostscript installed", bool(shutil.which("gs")), "brew install ghostscript")
    check("lp installed", bool(shutil.which("lp")), "CUPS ships with macOS")

    remote_ok = False
    if shutil.which("rclone"):
        res = subprocess.run(["rclone", "listremotes"], capture_output=True, text=True)
        remote_ok = f"{remote}:" in res.stdout.split()
    check(f"rclone remote '{remote}' configured", remote_ok, "run `printboard setup`")
    check("deck id configured (local)", bool(deck.get("doc_id")),
          "run `printboard setup` to save the deck id locally")

    res = subprocess.run(["lpstat", "-d"], capture_output=True, text=True)
    print(f"  • {res.stdout.strip() or 'no default printer (set one with lpoptions -d <printer>)'}")

    if remote_ok and deck.get("doc_id"):
        tmp = Path(tempfile.mkdtemp(prefix="printboard-doctor-"))
        try:
            pages = page_texts(export_deck(deck, tmp))
            check(f"deck exports from Drive ({len(pages)} pages)", True)
        except SystemExit:
            check("deck exports from Drive", False, "auth/scope issue — re-run `printboard setup`")
        finally:
            shutil.rmtree(tmp, ignore_errors=True)

    print(f"\n{'All good.' if ok else 'Some checks failed — see hints above.'}")
    return 0 if ok else 1


def cmd_setup(argv: list[str]) -> int:
    """Authorise rclone and save the (private) deck id to the local config."""
    ap = argparse.ArgumentParser(prog="printboard setup")
    ap.add_argument("--manifest", default=None)
    ap.add_argument("--deck", help="Google Slides URL or file id of the deck")
    args = ap.parse_args(argv)
    manifest = json.loads(resolve_manifest(args.manifest).read_text())
    remote = effective_deck(manifest, load_config())["rclone_remote"]

    if not shutil.which("rclone"):
        die("rclone is not installed. Install it first:  brew install rclone")

    print(f"Setting up the '{remote}' rclone remote (read-only Google Drive).")
    print("A browser window opens — log in and click Allow.")
    print("You do NOT need to pick a Shared Drive: printboard finds the deck by id.\n")
    res = subprocess.run(["rclone", "config", "create", remote, "drive",
                          "scope=drive.readonly"])
    if res.returncode != 0:
        die("rclone setup failed. If your org blocked the app, create your own OAuth "
            "client in Google Cloud Console and re-run setup (see README.md).")

    raw = args.deck
    if not raw:
        if not sys.stdin.isatty():
            die("pass the deck with --deck '<Slides URL or id>' (non-interactive).")
        raw = input("\nPaste the Google Slides URL or file id of the deck: ")
    doc_id = extract_doc_id(raw or "")
    if not doc_id:
        die("couldn't read a deck id from that — expected a Slides URL or a file id.")

    cfg = load_config()
    cfg["doc_id"] = doc_id
    cfg.setdefault("rclone_remote", remote)
    save_config(cfg)
    print(f"\n✓ remote configured and deck id saved to {CONFIG_PATH}. Verifying…\n")
    return cmd_doctor(["--manifest", args.manifest] if args.manifest else [])


def main():
    argv = sys.argv[1:]
    if argv and argv[0] == "setup":
        sys.exit(cmd_setup(argv[1:]))
    if argv and argv[0] == "doctor":
        sys.exit(cmd_doctor(argv[1:]))
    if argv and argv[0] == "printer":
        sys.exit(cmd_printer(argv[1:]))

    ap = argparse.ArgumentParser(
        prog="printboard", add_help=True,
        description="Print the Enabler board's papers "
                    "(also: `printboard setup`, `printboard printer`, `printboard doctor`).",
        epilog="setup: configure rclone auth.  printer: choose the default printer.  "
               "doctor: check deps + deck export.")
    ap.add_argument("selectors", nargs="*",
                    help="optional version and/or paper id (e.g. `generic`, "
                         "`tech-working-conditions`, or both). No version → all variants (activation).")
    ap.add_argument("--count", type=int,
                    help="override copies (a named paper defaults to 1; activation uses version_counts)")
    ap.add_argument("--printer", help="printer name (default: manifest, else system default)")
    ap.add_argument("--to-pdf", metavar="PATH",
                    help="write the sized pages to one PDF instead of printing (no printer "
                         "needed); a directory names the file for you")
    ap.add_argument("--from-pdf", help="use this local PDF instead of exporting from Drive")
    ap.add_argument("--manifest", default=None, help="path to manifest.json (overrides the default lookup)")
    ap.add_argument("--dry-run", action="store_true", help="print the lp commands, don't run them")
    ap.add_argument("--force", action="store_true",
                    help="print even on ambiguous/fuzzy title matches (uses the first page)")
    ap.add_argument("--list-titles", action="store_true",
                    help="dump page → first line for every page (debug the deck contract)")
    args = ap.parse_args()

    manifest = json.loads(resolve_manifest(args.manifest).read_text())
    config = load_config()
    deck = effective_deck(manifest, config)
    pcfg = manifest.get("print", {})
    printer = args.printer or config.get("printer") or pcfg.get("printer")
    lp_options = pcfg.get("lp_options", [])
    default_orientation = pcfg.get("orientation", "portrait")
    safe_margin = pcfg.get("safe_margin_mm", 0.0)
    version_counts = pcfg.get("version_counts", {})
    papers = manifest.get("papers", [])

    version_set = set(version_counts) | {v for p in papers for v in p.get("variants", {})}
    paper_ids = {p["id"] for p in papers}
    chosen_version = chosen_paper = None
    for tok in args.selectors:
        if tok in version_set:
            chosen_version = tok
        elif tok in paper_ids:
            chosen_paper = tok
        else:
            die(f"unknown selector '{tok}'. versions: {sorted(version_set)} | "
                f"papers: {sorted(paper_ids)}")

    tmp = Path(tempfile.mkdtemp(prefix="printboard-"))
    try:
        if args.from_pdf:
            pdf = Path(os.path.expanduser(args.from_pdf))
            if not pdf.exists():
                die(f"--from-pdf not found: {pdf}")
        else:
            pdf = export_deck(deck, tmp)

        pages = page_texts(pdf)

        if args.list_titles:
            print(f"# {len(pages)} pages in {pdf.name}\n")
            for i, text in enumerate(pages, start=1):
                lines = page_lines(text)
                print(f"{i:>3}: {lines[0] if lines else '(no text)'}")
            return

        # Build the print plan: (paper, version, title, count). No version selected
        # → every variant of every (selected) paper = activation.
        selected_papers = [p for p in papers
                           if chosen_paper is None or p["id"] == chosen_paper]
        plan = []
        for p in selected_papers:
            variants = p.get("variants", {})
            for v in ([chosen_version] if chosen_version else list(variants)):
                spec = variants.get(v)
                if not spec:
                    if chosen_version:
                        warn(f"{p['id']}: no '{v}' variant — skipped.")
                    continue
                if isinstance(spec, dict):
                    title, per_variant = spec.get("title"), spec.get("count")
                else:
                    title, per_variant = spec, None
                # version_counts are per-board-activation quantities. Naming a specific
                # paper is a quick single reprint, so it defaults to 1 — otherwise the
                # activation counts (e.g. generic ×5) silently apply to a one-off print.
                if args.count is not None:
                    count = args.count
                elif per_variant is not None:
                    count = per_variant
                elif chosen_paper is not None:
                    count = 1
                else:
                    count = version_counts.get(v, 1)
                plan.append((p, v, title, count))

        scope = " ".join(x for x in (chosen_version, chosen_paper) if x) or "activation (all variants)"
        if args.to_pdf:
            slug = "-".join(x for x in (chosen_version, chosen_paper) if x) or "board"
            export_pdf = Path(os.path.expanduser(args.to_pdf))
            if export_pdf.is_dir() or args.to_pdf.endswith(("/", os.sep)):
                export_pdf = export_pdf / f"printboard-{slug}.pdf"
            if args.count is not None:
                warn("--count is ignored with --to-pdf (one page per variant).")
            verb = "Exporting"
        else:
            export_pdf = None
            verb = "Printing"
        print(f"{verb} the board — {scope}"
              f"{f' → {export_pdf}' if export_pdf else ''}"
              f"{'  [dry run]' if args.dry_run else ''}\n")
        if not plan:
            die("nothing to export." if export_pdf else "nothing to print for that selection.")

        page_cache = {}
        pdf_pages = []
        printed, skipped = 0, 0
        for p, v, title, count in plan:
            pid = p["id"]
            info = page_cache.setdefault(pid, assign_paper_pages(p, pages))[v]
            status, page = info["status"], info["page"]
            if status != "ok":
                if status in ("ambiguous", "fuzzy") and args.force:
                    page = info["pages"][0]
                    warn(f'{pid}/{v}: {status} match for "{title}" {info["pages"]} — using {page} (--force)')
                elif status == "ambiguous":
                    warn(f'{pid}/{v}: "{title}" matches slides {info["pages"]} — make it unique (or --force). Skipped.')
                    skipped += 1
                    continue
                elif status == "fuzzy":
                    warn(f'{pid}/{v}: "{title}" only appears inside a slide {info["pages"]}, not as its title. Skipped.')
                    skipped += 1
                    continue
                else:
                    warn(f'{pid}/{v}: title "{title}" not found in deck — skipped.')
                    skipped += 1
                    continue
            orientation = p.get("orientation", default_orientation)
            size = p["size"]
            count_col = "" if export_pdf else f"×{count}  "
            label = f"{pid:<24} {v:<13} {size} {orientation:<9} {count_col}p{page}  «{title}»"
            if args.dry_run:
                action = (f"add 1 page to {export_pdf.name}" if export_pdf
                          else f"gs: size page {page} → {size} {orientation};  "
                               f"lp -n {count} -o media={size}")
                print(f"  {label}\n      {action}")
                printed += 1
                continue
            sized = scale_page(pdf, page, size, orientation, tmp, safe_margin)
            if export_pdf is not None:
                pdf_pages.append(sized)               # one page per variant; --count doesn't apply
                print(f"  ✓ {label}")
                printed += 1
                continue
            cmd = lp_command(sized, count, size, printer, lp_options)
            res = subprocess.run(cmd)
            print(f"  {'✓' if res.returncode == 0 else '✗'} {label}")
            if res.returncode != 0:
                warn(f"{pid}: lp exited {res.returncode}")
            printed += 1

        if export_pdf is not None and not args.dry_run and pdf_pages:
            merge_pdfs(pdf_pages, export_pdf)
            print(f"\n{printed} variant(s) exported to {export_pdf}"
                  f"{f'; {skipped} skipped' if skipped else ''}.")
        else:
            print(f"\n{printed} variant(s) "
                  f"{'planned' if args.dry_run else ('exported' if export_pdf else 'sent')}"
                  f"{f'; {skipped} skipped' if skipped else ''}.")
        if skipped and not args.force:
            print("  (skipped variants need a unique, exact slide title — see the warnings above.)")
    finally:
        shutil.rmtree(tmp, ignore_errors=True)


if __name__ == "__main__":
    main()
